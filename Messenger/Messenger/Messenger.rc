#include <windows.h>
#include "resource.h"

IDD_LOGIN DIALOGEX 0, 0, 400, 310
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Подключение"
FONT 14, "Segoe UI"
BEGIN
    LTEXT "Сервер:", -1, 20, 20, 100, 22
    EDITTEXT IDC_DLG_HOST, 120, 18, 250, 26, WS_BORDER | WS_TABSTOP
    LTEXT "Порт:", -1, 20, 55, 100, 22
    EDITTEXT IDC_DLG_PORT, 120, 53, 100, 26, WS_BORDER | WS_TABSTOP
    LTEXT "Логин:", -1, 20, 90, 100, 22
    EDITTEXT IDC_DLG_USER, 120, 88, 250, 26, WS_BORDER | WS_TABSTOP
    LTEXT "Пароль:", -1, 20, 125, 100, 22
    EDITTEXT IDC_DLG_PASS, 120, 123, 250, 26, WS_BORDER | WS_PASSWORD | WS_TABSTOP
    DEFPUSHBUTTON "Войти", IDC_DLG_LOGIN_BTN, 20, 180, 110, 36, WS_TABSTOP
    PUSHBUTTON "Регистрация", IDC_DLG_REGISTER, 140, 180, 130, 36, WS_TABSTOP
    PUSHBUTTON "Отмена", IDCANCEL, 280, 180, 90, 36, WS_TABSTOP
END

IDD_DEPLOY DIALOGEX 0, 0, 500, 420
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "SSH развертывание"
FONT 14, "Segoe UI"
BEGIN
    LTEXT "IP сервера:", -1, 20, 20, 120, 22
    EDITTEXT IDC_SSH_HOST, 150, 18, 320, 26, WS_BORDER | WS_TABSTOP
    LTEXT "Порт SSH:", -1, 20, 55, 120, 22
    EDITTEXT IDC_SSH_PORT, 150, 53, 80, 26, WS_BORDER | WS_TABSTOP
    LTEXT "Пользователь:", -1, 20, 90, 120, 22
    EDITTEXT IDC_SSH_USER, 150, 88, 200, 26, WS_BORDER | WS_TABSTOP
    LTEXT "Пароль:", -1, 20, 125, 120, 22
    EDITTEXT IDC_SSH_PASS, 150, 123, 200, 26, WS_BORDER | WS_PASSWORD | WS_TABSTOP
    LTEXT "Лог:", -1, 20, 165, 100, 22
    EDITTEXT IDC_SSH_LOG, 20, 188, 455, 180, WS_BORDER | WS_VSCROLL | ES_MULTILINE | ES_READONLY | ES_AUTOVSCROLL
    DEFPUSHBUTTON "Развернуть!", IDC_SSH_DEPLOY_BTN, 20, 380, 130, 32, WS_TABSTOP
    PUSHBUTTON "Закрыть", IDCANCEL, 385, 380, 90, 32, WS_TABSTOP
END
