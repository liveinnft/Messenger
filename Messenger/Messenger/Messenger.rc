#include <windows.h>
#include "Resource.h"

// Диалог подключения (ID = 102) - компактный и изменяемый
102 DIALOGEX 0, 0, 320, 240
STYLE DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME | WS_MINIMIZEBOX
CAPTION "Подключение к серверу"
FONT 14, "Segoe UI"
BEGIN
    LTEXT "Сервер:", -1, 15, 15, 60, 20
    EDITTEXT 201, 85, 12, 220, 24, WS_BORDER | WS_TABSTOP | ES_AUTOHSCROLL
    LTEXT "Порт:", -1, 15, 45, 60, 20
    EDITTEXT 202, 85, 42, 80, 24, WS_BORDER | WS_TABSTOP
    LTEXT "Логин:", -1, 15, 75, 60, 20
    EDITTEXT 203, 85, 72, 220, 24, WS_BORDER | WS_TABSTOP | ES_AUTOHSCROLL
    LTEXT "Пароль:", -1, 15, 105, 60, 20
    EDITTEXT 204, 85, 102, 220, 24, WS_BORDER | ES_PASSWORD | WS_TABSTOP
    LTEXT "Нет аккаунта? Нажмите ""Регистрация""", -1, 15, 140, 250, 18
    DEFPUSHBUTTON "Войти", 206, 15, 175, 90, 32, WS_TABSTOP
    PUSHBUTTON "Регистрация", 205, 115, 175, 95, 32, WS_TABSTOP
    PUSHBUTTON "Отмена", IDCANCEL, 220, 175, 85, 32, WS_TABSTOP
END

// Диалог развертывания (ID = 103)
103 DIALOGEX 0, 0, 500, 420
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Развертывание сервера"
FONT 14, "Segoe UI"
BEGIN
    LTEXT "IP сервера:", -1, 20, 20, 120, 22
    EDITTEXT 301, 150, 18, 320, 26, WS_BORDER | WS_TABSTOP
    LTEXT "Порт SSH:", -1, 20, 55, 120, 22
    EDITTEXT 302, 150, 53, 80, 26, WS_BORDER | WS_TABSTOP
    LTEXT "Пользователь:", -1, 20, 90, 120, 22
    EDITTEXT 303, 150, 88, 200, 26, WS_BORDER | WS_TABSTOP
    LTEXT "Пароль:", -1, 20, 125, 120, 22
    EDITTEXT 304, 150, 123, 200, 26, WS_BORDER | ES_PASSWORD | WS_TABSTOP
    LTEXT "Лог:", -1, 20, 165, 100, 22
    EDITTEXT 305, 20, 188, 455, 180, WS_BORDER | WS_VSCROLL | ES_MULTILINE | ES_READONLY | ES_AUTOVSCROLL
    DEFPUSHBUTTON "Развернуть!", 306, 20, 380, 130, 32, WS_TABSTOP
    PUSHBUTTON "Закрыть", IDCANCEL, 385, 380, 90, 32, WS_TABSTOP
END
